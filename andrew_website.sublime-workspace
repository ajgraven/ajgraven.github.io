			"contents": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Arnold Tongues Visualizer</title>\n<style>\n/*\n * =========================================================================\n *  STYLES — Dark scientific-instrument theme\n * =========================================================================\n */\n* { margin: 0; padding: 0; box-sizing: border-box; }\n\n:root {\n    --bg-deep:    #0b0e17;\n    --bg-panel:   #121728;\n    --bg-input:   #0a0d18;\n    --border:     #1e2845;\n    --accent:     #4e7cff;\n    --accent-dim: #2b4a99;\n    --text:       #c8cce0;\n    --text-dim:   #6b7394;\n    --text-bright:#eef0ff;\n    --danger:     #ff5c5c;\n    --font-mono:  'JetBrains Mono', 'Fira Code', 'SF Mono', 'Cascadia Code', monospace;\n    --font-ui:    'DM Sans', 'Segoe UI', system-ui, sans-serif;\n}\n\n@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');\n\nbody {\n    background: var(--bg-deep);\n    color: var(--text);\n    font-family: var(--font-ui);\n    overflow: hidden;\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n}\n\n/* ---------- Top control bar ---------- */\n#controls {\n    background: var(--bg-panel);\n    padding: 10px 18px;\n    display: flex;\n    align-items: center;\n    gap: 22px;\n    flex-wrap: wrap;\n    border-bottom: 1px solid var(--border);\n    z-index: 10;\n    min-height: 48px;\n}\n\n#controls .group {\n    display: flex;\n    align-items: center;\n    gap: 7px;\n}\n\n#controls .sep {\n    width: 1px;\n    height: 24px;\n    background: var(--border);\n}\n\n#controls label {\n    font-size: 12px;\n    font-weight: 500;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    user-select: none;\n}\n\nbutton {\n    background: var(--bg-input);\n    color: var(--text);\n    border: 1px solid var(--border);\n    padding: 5px 13px;\n    border-radius: 5px;\n    cursor: pointer;\n    font-size: 12px;\n    font-family: var(--font-ui);\n    font-weight: 500;\n    transition: background 0.15s, border-color 0.15s;\n}\nbutton:hover { background: var(--accent-dim); border-color: var(--accent); }\nbutton.active {\n    background: var(--accent-dim);\n    border-color: var(--accent);\n    color: var(--text-bright);\n}\n\ninput[type=\"number\"] {\n    background: var(--bg-input);\n    color: var(--text-bright);\n    border: 1px solid var(--border);\n    padding: 4px 8px;\n    border-radius: 5px;\n    width: 72px;\n    font-size: 13px;\n    font-family: var(--font-mono);\n    text-align: center;\n}\ninput[type=\"number\"]:focus {\n    outline: none;\n    border-color: var(--accent);\n}\n\n#view-info {\n    font-size: 11px;\n    font-family: var(--font-mono);\n    color: var(--text-dim);\n    margin-left: auto;\n    white-space: nowrap;\n}\n\n/* ---------- Canvas container ---------- */\n#canvas-container {\n    flex: 1;\n    position: relative;\n    overflow: hidden;\n    cursor: crosshair;\n}\n\ncanvas {\n    display: block;\n    width: 100%;\n    height: 100%;\n}\n\n/* ---------- Axis labels ---------- */\n.axis-label {\n    position: absolute;\n    font-size: 15px;\n    font-family: var(--font-mono);\n    font-style: italic;\n    color: var(--text-dim);\n    pointer-events: none;\n    user-select: none;\n    opacity: 0.7;\n}\n#axis-x { bottom: 10px; left: 50%; transform: translateX(-50%); }\n#axis-y { left: 12px;   top: 50%; transform: translateY(-50%) rotate(-90deg); }\n\n/* ---------- Tooltip ---------- */\n#tooltip {\n    position: absolute;\n    background: rgba(11, 14, 23, 0.93);\n    color: var(--text-bright);\n    padding: 8px 13px;\n    border-radius: 6px;\n    font-size: 12px;\n    font-family: var(--font-mono);\n    pointer-events: none;\n    border: 1px solid var(--accent-dim);\n    display: none;\n    z-index: 100;\n    line-height: 1.65;\n    white-space: nowrap;\n    backdrop-filter: blur(6px);\n    box-shadow: 0 4px 20px rgba(0,0,0,0.5);\n}\n#tooltip .frac {\n    color: var(--accent);\n    font-weight: 500;\n    font-size: 14px;\n}\n\n/* ---------- Loading overlay ---------- */\n#loading {\n    position: absolute;\n    inset: 0;\n    background: var(--bg-deep);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 200;\n    font-size: 14px;\n    color: var(--text-dim);\n    transition: opacity 0.4s;\n}\n#loading.hidden { opacity: 0; pointer-events: none; }\n\n/* ---------- Header ---------- */\n#header {\n    background: var(--bg-panel);\n    padding: 14px 20px 10px;\n    border-bottom: 1px solid var(--border);\n}\n#header h1 {\n    font-family: var(--font-ui);\n    font-size: 20px;\n    font-weight: 600;\n    color: var(--text-bright);\n    letter-spacing: -0.01em;\n    margin-bottom: 4px;\n}\n#header p {\n    font-size: 13px;\n    line-height: 1.55;\n    color: var(--text-dim);\n    max-width: 960px;\n}\n#header .math {\n    font-family: var(--font-mono);\n    font-size: 12px;\n    color: var(--text);\n}\n\n/* ---------- Footer / instructions ---------- */\n#footer {\n    background: var(--bg-panel);\n    padding: 8px 20px;\n    border-top: 1px solid var(--border);\n    display: flex;\n    gap: 28px;\n    flex-wrap: wrap;\n    align-items: center;\n}\n#footer .instruction {\n    font-size: 11.5px;\n    color: var(--text-dim);\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    white-space: nowrap;\n}\n#footer .key {\n    display: inline-block;\n    background: var(--bg-input);\n    border: 1px solid var(--border);\n    border-radius: 4px;\n    padding: 1px 7px;\n    font-family: var(--font-mono);\n    font-size: 10.5px;\n    color: var(--text);\n}\n</style>\n</head>\n<body>\n\n<!-- ===== Header ===== -->\n<div id=\"header\">\n    <h1><a href=\"https://en.wikipedia.org/wiki/Arnold_tongue\">Arnold Tongues</a></h1>\n    <p>\n        Mode-locking regions in the parameter plane of the standard circle map\n        <span class=\"math\">θ<sub>n+1</sub> = θ<sub>n</sub> + Ω − (K/2π) sin(2πθ<sub>n</sub>)</span>.\n        Each tongue is a region where the winding number locks to a rational value <span class=\"math\">p/q</span>.\n        At <span class=\"math\">K = 0</span> the tongues are infinitely thin (only rational Ω);\n        they widen as coupling <span class=\"math\">K</span> increases and begin to overlap past <span class=\"math\">K = 1</span>,\n        where the map loses invertibility and chaotic dynamics emerge.\n    </p>\n</div>\n\n<!-- ===== Control Bar ===== -->\n<div id=\"controls\">\n    <div class=\"group\">\n        <label>Color</label>\n        <button id=\"btn-continuous\" class=\"active\" onclick=\"setColorMode(0)\">Continuous</button>\n        <button id=\"btn-discrete\" onclick=\"setColorMode(1)\">Discrete</button>\n    </div>\n    <div class=\"sep\"></div>\n    <div class=\"group\">\n        <label>Iterations</label>\n        <input type=\"number\" id=\"iter-input\" value=\"200\" min=\"10\" max=\"4000\" step=\"10\">\n    </div>\n    <div class=\"sep\"></div>\n    <div class=\"group\">\n        <button id=\"btn-reset\" onclick=\"resetView()\">Reset View</button>\n    </div>\n    <span id=\"view-info\"></span>\n</div>\n\n<!-- ===== Canvas and overlays ===== -->\n<div id=\"canvas-container\">\n    <canvas id=\"glcanvas\"></canvas>\n    <div class=\"axis-label\" id=\"axis-x\">Ω</div>\n    <div class=\"axis-label\" id=\"axis-y\">K</div>\n    <div id=\"tooltip\"></div>\n    <div id=\"loading\">Compiling shaders…</div>\n</div>\n\n<!-- ===== Footer / Controls Instructions ===== -->\n<div id=\"footer\">\n    <div class=\"instruction\"><span class=\"key\">Scroll</span> Zoom in / out (centered on cursor)</div>\n    <div class=\"instruction\"><span class=\"key\">Click + Drag</span> Pan the view</div>\n    <div class=\"instruction\"><span class=\"key\">Hover</span> Show winding number ω as p/q</div>\n    <div class=\"instruction\"><span class=\"key\">Reset View</span> Return to Ω, K ∈ [0, 1]</div>\n</div>\n\n<script>\n/*\n * =========================================================================\n *  Arnold Tongues Visualizer\n * =========================================================================\n *\n *  Renders the parameter plane (Ω, K) of the standard Arnold circle map\n *\n *      θ_{n+1} = θ_n + Ω − (K / 2π) sin(2π θ_n)\n *\n *  using a WebGL 2.0 fragment shader that computes the winding number\n *\n *      ω = lim_{n→∞} θ_n / n     (starting from θ_0 = 0)\n *\n *  for every pixel in parallel on the GPU.\n *\n *  Two coloring modes are available:\n *    • Continuous — hue mapped from the winding number (shows devil's\n *      staircase structure; each tongue is a band of constant hue).\n *    • Discrete  — color by the denominator q of the best rational\n *      approximation p/q via continued fractions.  Mode-locked regions\n *      (tongues) get a distinct color per q; quasiperiodic/chaotic\n *      regions are rendered dark.\n *\n *  Interaction:\n *    • Mouse wheel to zoom (centered on cursor)\n *    • Click + drag to pan\n *    • Hover for a tooltip showing Ω, K, and the winding number as p/q\n *\n * =========================================================================\n */\n\n\n/* -----------------------------------------------------------------------\n *  1.  GLSL SHADERS\n * ----------------------------------------------------------------------- */\n\n/**\n * Vertex shader — renders a full-screen quad.\n * Two triangles covering clip space [-1, 1]².\n */\nconst VERT_SRC = `#version 300 es\nprecision highp float;\n\n// Full-screen triangle strip: 4 vertices → 2 triangles\nconst vec2 QUAD[4] = vec2[4](\n    vec2(-1, -1),\n    vec2( 1, -1),\n    vec2(-1,  1),\n    vec2( 1,  1)\n);\n\nvoid main() {\n    gl_Position = vec4(QUAD[gl_VertexID], 0.0, 1.0);\n}\n`;\n\n/**\n * Fragment shader — the computational core.\n *\n * For each pixel, maps screen coordinates to (Ω, K), iterates the\n * circle map, computes the winding number, and outputs a color.\n */\nconst FRAG_SRC = `#version 300 es\nprecision highp float;\n\n/* --- Uniforms --------------------------------------------------------- */\nuniform vec2  u_resolution;       // canvas size in pixels\nuniform float u_xMin, u_xMax;     // Ω range\nuniform float u_yMin, u_yMax;     // K range\nuniform int   u_iterations;       // number of map iterations\nuniform int   u_colorMode;        // 0 = continuous, 1 = discrete\n\nout vec4 fragColor;\n\n/* --- Constants -------------------------------------------------------- */\nconst float PI     = 3.14159265358979323846;\nconst float TWO_PI = 6.28318530717958647692;\nconst int   MAX_ITER = 4000;      // shader loop ceiling\n\n/* -----------------------------------------------------------------------\n *  computeWindingNumber\n *\n *  Iterates the lifted circle map   f(θ) = θ + Ω − (K/2π) sin(2πθ)\n *  starting from θ₀ = 0.  Returns  θ_N / N.\n *\n *  We do NOT reduce θ mod 1 — the lift accumulates total rotation so\n *  that θ_N / N converges to the true winding number.\n * ----------------------------------------------------------------------- */\nfloat computeWindingNumber(float omega, float K) {\n    float theta = 0.0;\n\n    for (int i = 0; i < MAX_ITER; i++) {\n        if (i >= u_iterations) break;\n        theta += omega - (K / TWO_PI) * sin(TWO_PI * theta);\n    }\n\n    return theta / float(u_iterations);\n}\n\n/* -----------------------------------------------------------------------\n *  hsv2rgb  — standard Hue-Saturation-Value to RGB conversion\n * ----------------------------------------------------------------------- */\nvec3 hsv2rgb(float h, float s, float v) {\n    vec3 c = vec3(h, s, v);\n    vec4 K = vec4(1.0, 2.0/3.0, 1.0/3.0, 3.0);\n    vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);\n    return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);\n}\n\n/* -----------------------------------------------------------------------\n *  bestRational\n *\n *  Given a value x, finds the best rational approximation p/q using\n *  the continued fraction algorithm.  Operates on fract(x) ∈ [0, 1).\n *\n *  Returns vec3(p, q, |x − p/q|).\n *\n *  We cap the denominator at 200 to keep tongue identification clean.\n * ----------------------------------------------------------------------- */\nvec3 bestRational(float x) {\n    float target = fract(x);\n    if (target < 0.0) target += 1.0;         // ensure [0, 1)\n\n    /* Edge cases: target ≈ 0  or  ≈ 1 */\n    if (target < 1e-6)       return vec3(0.0, 1.0, target);\n    if (1.0 - target < 1e-6) return vec3(1.0, 1.0, 1.0 - target);\n\n    /*\n     * Standard continued-fraction convergent recurrence.\n     *\n     * We start with the \"minus-one\" convergents  h_{-1}/k_{-1} = 1/0\n     * and  h_0/k_0 = 0/1  (since a_0 = floor(target) = 0 for target<1).\n     * Then we immediately invert the remainder  r = 1/target  and\n     * proceed with the main loop.\n     */\n    float h_prev = 1.0, k_prev = 0.0;\n    float h_curr = 0.0, k_curr = 1.0;\n    float r = 1.0 / target;\n\n    float bestP = 0.0, bestQ = 1.0, bestErr = target;\n\n    for (int i = 0; i < 20; i++) {\n        float a = floor(r);                   // next partial quotient\n\n        float h_next = a * h_curr + h_prev;\n        float k_next = a * k_curr + k_prev;\n\n        if (k_next > 200.0) break;            // denominator cap\n\n        float err = abs(target - h_next / k_next);\n        if (err < bestErr) {\n            bestErr = err;\n            bestP   = h_next;\n            bestQ   = k_next;\n        }\n\n        if (err < 1e-10) break;               // exact match\n\n        h_prev = h_curr;  h_curr = h_next;\n        k_prev = k_curr;  k_curr = k_next;\n\n        float frac = r - a;\n        if (abs(frac) < 1e-10) break;         // CF terminated\n        r = 1.0 / frac;\n    }\n\n    return vec3(bestP, bestQ, bestErr);\n}\n\n/* -----------------------------------------------------------------------\n *  denominatorColor\n *\n *  Assigns a distinct hue to each denominator q.  Low q gets saturated,\n *  hand-picked colours; high q cycles via the golden angle.\n * ----------------------------------------------------------------------- */\nvec3 denominatorColor(float q, float p) {\n    /* Hand-tuned palette for the most prominent tongues */\n    if (q <= 1.0) return vec3(0.92, 0.25, 0.20);   // q=1  vivid red\n    if (q <= 2.0) return vec3(0.20, 0.52, 1.00);   // q=2  strong blue\n    if (q <= 3.0) return vec3(0.18, 0.85, 0.35);   // q=3  green\n    if (q <= 4.0) return vec3(1.00, 0.65, 0.10);   // q=4  amber\n    if (q <= 5.0) return vec3(0.72, 0.22, 0.92);   // q=5  purple\n    if (q <= 6.0) return vec3(0.10, 0.82, 0.82);   // q=6  teal\n    if (q <= 7.0) return vec3(0.95, 0.42, 0.60);   // q=7  pink\n    if (q <= 8.0) return vec3(0.55, 0.80, 0.20);   // q=8  lime\n\n    /* Higher q: golden-ratio hue cycling with fading brightness */\n    float hue = fract((p / q) + q * 0.618033988749895);\n    float bri = max(0.35, 1.0 - q / 40.0);\n    return hsv2rgb(hue, 0.75, bri);\n}\n\n/* -----------------------------------------------------------------------\n *  main  — entry point for every pixel\n * ----------------------------------------------------------------------- */\nvoid main() {\n    /* Map pixel to parameter space */\n    vec2  uv    = gl_FragCoord.xy / u_resolution;\n    float omega = mix(u_xMin, u_xMax, uv.x);\n    float K     = mix(u_yMin, u_yMax, uv.y);\n\n    /* Compute winding number */\n    float w = computeWindingNumber(omega, K);\n\n    vec3 color;\n\n    if (u_colorMode == 0) {\n        /* ---- Continuous mode ----\n         * Map the winding number to a hue.  fract(w) ensures [0,1).\n         * A gentle brightness gradient in K adds depth.\n         */\n        float hue = fract(w);\n        float val = 0.92 + 0.06 * (1.0 - uv.y);    // slightly brighter at bottom\n        color = hsv2rgb(hue, 0.82, val);\n\n    } else {\n        /* ---- Discrete mode ----\n         * Find the best rational p/q and check if we are \"close enough\"\n         * to call this pixel mode-locked.\n         *\n         * Threshold rationale:  inside a tongue the computed winding\n         * number deviates from p/q by O(1/N) due to transient effects.\n         * We use a threshold proportional to 1/(q·N) to account for\n         * the fact that thinner tongues (larger q) need tighter tolerance.\n         */\n        vec3  pqe       = bestRational(w);\n        float p         = pqe.x;\n        float q         = pqe.y;\n        float err       = pqe.z;\n        float threshold = 0.45 / (q * float(u_iterations));\n\n        if (err < threshold) {\n            color = denominatorColor(q, p);\n        } else {\n            /* Quasiperiodic / chaotic — dark background with subtle\n               gradient so it doesn't look completely flat */\n            color = vec3(0.04 + 0.03 * uv.y);\n        }\n    }\n\n    fragColor = vec4(color, 1.0);\n}\n`;\n\n\n/* -----------------------------------------------------------------------\n *  2.  APPLICATION STATE\n * ----------------------------------------------------------------------- */\n\n/** View bounds — what region of (Ω, K) space is visible */\nlet xMin = 0.0, xMax = 1.0;\nlet yMin = 0.0, yMax = 1.0;\n\n/** Default bounds (for reset) */\nconst DEF_XMIN = 0.0, DEF_XMAX = 1.0;\nconst DEF_YMIN = 0.0, DEF_YMAX = 1.0;\n\n/** Rendering parameters */\nlet iterations = 200;\nlet colorMode  = 0;   // 0 = continuous, 1 = discrete\n\n/** Flag: do we need to redraw? */\nlet dirty = true;\n\n/** Mouse interaction state */\nlet isDragging  = false;\nlet dragStartX  = 0;\nlet dragStartY  = 0;\nlet dragBoundsX = 0;   // xMin at drag start\nlet dragBoundsY = 0;   // yMin at drag start\n\n\n/* -----------------------------------------------------------------------\n *  3.  WEBGL SETUP\n * ----------------------------------------------------------------------- */\n\nconst canvas = document.getElementById('glcanvas');\nconst container = document.getElementById('canvas-container');\nconst gl = canvas.getContext('webgl2', { antialias: false, depth: false });\n\nif (!gl) {\n    document.getElementById('loading').textContent =\n        'WebGL 2.0 is not supported by your browser.';\n    throw new Error('WebGL 2 not available');\n}\n\n/**\n * compileShader — compiles a GLSL shader and throws on error.\n *\n * @param {number} type   gl.VERTEX_SHADER or gl.FRAGMENT_SHADER\n * @param {string} source GLSL source code\n * @returns {WebGLShader}\n */\nfunction compileShader(type, source) {\n    const shader = gl.createShader(type);\n    gl.shaderSource(shader, source);\n    gl.compileShader(shader);\n    if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {\n        const log = gl.getShaderInfoLog(shader);\n        gl.deleteShader(shader);\n        throw new Error('Shader compile error:\\n' + log);\n    }\n    return shader;\n}\n\n/* Compile and link the shader program */\nconst vertShader = compileShader(gl.VERTEX_SHADER,   VERT_SRC);\nconst fragShader = compileShader(gl.FRAGMENT_SHADER, FRAG_SRC);\n\nconst program = gl.createProgram();\ngl.attachShader(program, vertShader);\ngl.attachShader(program, fragShader);\ngl.linkProgram(program);\n\nif (!gl.getProgramParameter(program, gl.LINK_STATUS)) {\n    throw new Error('Program link error:\\n' + gl.getProgramInfoLog(program));\n}\n\ngl.useProgram(program);\n\n/* Look up uniform locations (we'll set values each frame) */\nconst loc = {\n    resolution: gl.getUniformLocation(program, 'u_resolution'),\n    xMin:       gl.getUniformLocation(program, 'u_xMin'),\n    xMax:       gl.getUniformLocation(program, 'u_xMax'),\n    yMin:       gl.getUniformLocation(program, 'u_yMin'),\n    yMax:       gl.getUniformLocation(program, 'u_yMax'),\n    iterations: gl.getUniformLocation(program, 'u_iterations'),\n    colorMode:  gl.getUniformLocation(program, 'u_colorMode'),\n};\n\n\n/* -----------------------------------------------------------------------\n *  4.  CANVAS SIZING\n *\n *  We match the canvas backing-store resolution to the CSS pixel size\n *  (device pixel ratio = 1) for performance.  Full DPR rendering would\n *  quadruple the shader workload with little visual benefit for a\n *  continuously-coloured image.\n * ----------------------------------------------------------------------- */\n\nfunction resizeCanvas() {\n    const w = container.clientWidth;\n    const h = container.clientHeight;\n    if (canvas.width !== w || canvas.height !== h) {\n        canvas.width  = w;\n        canvas.height = h;\n        gl.viewport(0, 0, w, h);\n        dirty = true;\n    }\n}\n\nwindow.addEventListener('resize', () => { resizeCanvas(); });\nresizeCanvas();\n\n\n/* -----------------------------------------------------------------------\n *  5.  RENDERING\n * ----------------------------------------------------------------------- */\n\n/**\n * draw — sets all uniforms and issues the draw call.\n *\n * We draw a full-screen quad using gl.drawArrays with TRIANGLE_STRIP.\n * The vertex shader generates vertices from gl_VertexID (no VBO needed\n * in WebGL 2).  To make this work we need a bound VAO, even if empty.\n */\nconst vao = gl.createVertexArray();\ngl.bindVertexArray(vao);\n\nfunction draw() {\n    gl.uniform2f(loc.resolution, canvas.width, canvas.height);\n    gl.uniform1f(loc.xMin, xMin);\n    gl.uniform1f(loc.xMax, xMax);\n    gl.uniform1f(loc.yMin, yMin);\n    gl.uniform1f(loc.yMax, yMax);\n    gl.uniform1i(loc.iterations, iterations);\n    gl.uniform1i(loc.colorMode,  colorMode);\n\n    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);\n}\n\n/** Animation loop — only redraws when something changed */\nfunction frame() {\n    if (dirty) {\n        draw();\n        dirty = false;\n        updateViewInfo();\n    }\n    requestAnimationFrame(frame);\n}\n\n/* Hide the loading overlay once the first frame renders */\nrequestAnimationFrame(() => {\n    dirty = true;\n    frame();\n    setTimeout(() => {\n        document.getElementById('loading').classList.add('hidden');\n    }, 120);\n});\n\n\n/* -----------------------------------------------------------------------\n *  6.  MOUSE INTERACTION — Pan & Zoom\n * ----------------------------------------------------------------------- */\n\n/**\n * pixelToParam — converts a pixel position (relative to the canvas)\n * to parameter-space coordinates (Ω, K).\n *\n * Note: canvas y=0 is at the TOP, but WebGL y=0 is at the BOTTOM.\n * The fragment shader uses gl_FragCoord which has y=0 at bottom,\n * so our mapping here must flip y.\n */\nfunction pixelToParam(px, py) {\n    const w = canvas.width;\n    const h = canvas.height;\n    return {\n        omega: xMin + (px / w) * (xMax - xMin),\n        K:     yMin + ((h - py) / h) * (yMax - yMin)\n    };\n}\n\n/* --- Zoom (mouse wheel) ---\n *\n * Zooms centred on the cursor position so the point under the cursor\n * stays fixed.  Scroll up = zoom in (shrink the view window).\n */\ncanvas.addEventListener('wheel', (e) => {\n    e.preventDefault();\n\n    const rect  = canvas.getBoundingClientRect();\n    const px    = e.clientX - rect.left;\n    const py    = e.clientY - rect.top;\n    const param = pixelToParam(px, py);\n\n    /* Zoom factor: positive deltaY = scroll down = zoom out */\n    const zoomSpeed = 1.1;\n    const factor = e.deltaY > 0 ? zoomSpeed : 1 / zoomSpeed;\n\n    /* Scale the view around the cursor's parameter-space position */\n    xMin = param.omega + (xMin - param.omega) * factor;\n    xMax = param.omega + (xMax - param.omega) * factor;\n    yMin = param.K     + (yMin - param.K)     * factor;\n    yMax = param.K     + (yMax - param.K)     * factor;\n\n    dirty = true;\n}, { passive: false });\n\n/* --- Pan (click + drag) ---\n *\n * On mousedown we snapshot the current bounds.  During mousemove we\n * compute how far the mouse has moved in parameter-space units and\n * shift the bounds accordingly.\n */\ncanvas.addEventListener('